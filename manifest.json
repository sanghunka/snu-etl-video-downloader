{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.0.0",
  "description": "__MSG_extensionDescription__",
  "default_locale": "ko",
  "permissions": [
    "scripting",
    "declarativeNetRequest",
    "storage"
  ],
  "host_permissions": [
    "https://lcms.snu.ac.kr/*",
    "https://snu-cms-object.edge.naverncp.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16_gray.png",
      "48": "icons/icon48_gray.png",
      "128": "icons/icon128_gray.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://lcms.snu.ac.kr/*"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
